# Terraform
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfstate.backup
crash.log
crash.*.log

# Generated tfvars (may contain project IDs / local file paths)
terraform/terraform.tfvars
*.auto.tfvars

# Generated by scripts/register-conf-nodes.sh - contains Pexip-rendered
# conf-node bootstrap configs, which embed the OS admin password hash.
terraform/conf-configs.json

# Local SSH keys retrieved from Secret Manager
pexip_key
pexip_key.pub

# OS / editor cruft
.DS_Store
.idea/
.vscode/
*.swp

# Python bytecode (from tests/mock-pexip.py)
__pycache__/
*.pyc

# Local deployment configurations (contains passwords, licenses, etc.)
pexip-config.yaml
